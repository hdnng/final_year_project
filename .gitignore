# ============================================================
# EduVision AI — Root .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ────────────────────────────────────
venv/
ENV/
env/
.venv/

# ── Environment / Secrets ───────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ── IDE & Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
backend/logs/

# ── Database ────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
dump.rdb

# ── AI Models & Weights ─────────────────────────────────────
# Large binary model files — store with Git LFS or external storage
*.pt
*.pth
*.h5
*.keras
*.onnx
*.tflite
*.pkl
weights/
backend/ai_model/weights/
backend/ai_model/best_model.pth

# ── Runtime-generated Images ─────────────────────────────────
# Camera-captured frames saved by the application at runtime
images/
images/**

# ── Streamlit Cache ──────────────────────────────────────────
.streamlit/secrets.toml
frontend/.streamlit/secrets.toml

# ── Jupyter Notebooks ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Docker ───────────────────────────────────────────────────
.dockerignore

# ── Temporary files ──────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
